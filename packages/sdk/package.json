{
  "name": "@context-fabric/sdk",
  "version": "1.0.0",
  "description": "Public client SDK for Context Fabric: scope-aware, sanitized, budget-aware LLM context assembly. Zero runtime dependencies.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/josenaicipa/context-fabric.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/josenaicipa/context-fabric#readme",
  "bugs": {
    "url": "https://github.com/josenaicipa/context-fabric/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "bin": {
    "context-fabric": "./dist/src/cli.js"
  },
  "files": [
    "dist/src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.3.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test dist/test/*.test.js",
    "clean": "rm -rf dist",
    "prepack": "cp ../../LICENSE ./LICENSE",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "llm",
    "context",
    "rag",
    "agents",
    "sanitization",
    "token-budget"
  ],
  "devDependencies": {
    "typescript": "^6.0.3",
    "@types/node": "^25.9.2"
  }
}
